# Mapbox public token (client-side — restricted by URL in Mapbox dashboard)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Neon Postgres direct connection (used for migrations)
DATABASE_URL=

# Neon Postgres pooled connection (used by app at runtime in production)
# For local dev you can leave this blank and the app will use DATABASE_URL.
DATABASE_URL_POOLED=
