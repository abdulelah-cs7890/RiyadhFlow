{
  "ci": {
    "collect": {
      "url": [
        "http://127.0.0.1:3000/"
      ],
      "startServerCommand": "npm run start -- -p 3000 -H 127.0.0.1",
      "startServerReadyPattern": "started server",
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.7
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:best-practices": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:seo": [
          "warn",
          {
            "minScore": 0.85
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
